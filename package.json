{
  "name": "@kjerneverk/riotplan-commands-step",
  "version": "1.0.3",
  "description": "Step management commands for RiotPlan CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run lint && tsc --noEmit && vite build",
    "test": "npm run test:coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "precommit": "npm run build && npm run lint && npm run test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "author": "Tim O'Brien <tobrien@discursive.com>",
  "license": "Apache-2.0",
  "peerDependencies": {
    "@kjerneverk/riotplan": "^1.0.33",
    "commander": "^13.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.22.0",
    "@kjerneverk/riotplan": "^1.0.33",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.1.1",
    "commander": "^13.0.0",
    "eslint": "^9.22.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.15.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.3",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.1.1"
  }
}
